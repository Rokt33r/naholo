{
  "name": "naholo",
  "version": "0.18.4",
  "private": true,
  "license": "MIT",
  "packageManager": "pnpm@11.1.0",
  "scripts": {
    "dev": "next dev",
    "format": "pretty-quick",
    "format:all": "prettier --write .",
    "build": "next build",
    "start": "next start",
    "bump-cli": "pnpm tsx scripts/bump-cli.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "test": "pnpm typecheck",
    "typecheck": "tsc --noEmit",
    "test-db:create": "export $(grep -v '^#' .env.test | grep -v '^$' | xargs) && PGPASSWORD=$DB_PASSWORD createdb -h $DB_HOST -p $DB_PORT -U $DB_USER $DB_NAME",
    "test-db:drop": "export $(grep -v '^#' .env.test | grep -v '^$' | xargs) && PGPASSWORD=$DB_PASSWORD dropdb -h $DB_HOST -p $DB_PORT -U $DB_USER --if-exists $DB_NAME",
    "test-db:migrate": "export $(grep -v '^#' .env.test | grep -v '^$' | xargs) && pnpm drizzle-kit migrate",
    "test:integration": "vitest run",
    "tsx": "tsx --tsconfig tsconfig.scripts.json",
    "seed-op": "pnpm tsx scripts/seed-op.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1045.0",
    "@aws-sdk/client-ses": "^3.936.0",
    "@kenmon/email-otp-authenticator": "1.0.0-pre.1",
    "@kenmon/google-oauth-authenticator": "1.0.0-pre.1",
    "@kenmon/nextjs-adapter": "1.0.0-pre.3",
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@monaco-editor/react": "^4.7.0",
    "@next/env": "^16.0.8",
    "@next/mdx": "^16.2.4",
    "@polar-sh/checkout": "^0.2.1",
    "@polar-sh/sdk": "^0.47.1",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@sentry/nextjs": "^10",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-query": "^5.90.16",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.44.7",
    "input-otp": "^1.4.2",
    "jose": "^6.2.3",
    "kenmon": "1.0.0-pre.1",
    "lucide-react": "^1.20.0",
    "naholo-agent-transcripts": "workspace:*",
    "naholo-api": "workspace:*",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "pg": "^8.16.3",
    "radix-ui": "^1.4.3",
    "react": "19.2.0",
    "react-day-picker": "^9.11.1",
    "react-dom": "19.2.0",
    "react-markdown": "^10.1.0",
    "rehype-slug": "6.0.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "uuid": "^14.0.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/mdx": "^2.0.13",
    "@types/node": "^22",
    "@types/pg": "^8.15.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "baseline-browser-mapping": "^2.10.31",
    "drizzle-kit": "^0.31.6",
    "prettier": "^3.6.2",
    "pretty-quick": "^4.2.2",
    "simple-git-hooks": "^2.13.1",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vitest": "^4.1.4"
  }
}
