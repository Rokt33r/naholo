# Example Terraform variables file
# Copy this to terraform.tfvars and fill in your values

# AWS Configuration
aws_region   = "ap-northeast-1" # Tokyo
project_name = "naholo"
environment  = "production"

# Domain and SSL
acm_certificate_arn = "arn:aws:acm:ap-northeast-1:123456789012:certificate/abc-123-def-456"
domain_name         = "naholo.yourdomain.com"

# Application Secrets
session_secret = "generate-with-openssl-rand-base64-32"

# Google OAuth Configuration
google_oauth_client_id       = "YOUR_CLIENT_ID.apps.googleusercontent.com"
google_oauth_client_secret   = "YOUR_CLIENT_SECRET"
google_oauth_redirect_uri    = "https://your-domain.com/api/auth/google/callback"
google_oauth_state_secret    = "generate-with-openssl-rand-base64-32"

# GitHub Actions Configuration
github_repository = "Rokt33r/naholo"

# ECS Configuration (optional overrides)
# ecs_task_cpu       = 256  # 0.25 vCPU
# ecs_task_memory    = 512  # 512 MB
# ecs_desired_count  = 1    # Number of tasks

# RDS Configuration (optional overrides)
# db_instance_class     = "db.t4g.micro"
# db_allocated_storage  = 20
# db_name              = "naholo"
# db_username          = "naholo"
# db_ssl               = "true"

# Container Image (leave empty for first deployment)
# container_image = ""

base_url="https://naholo.app"

# File Storage Configuration
# Globally-unique S3 bucket name for server-side file storage (agent session transcripts, etc.)
s3_naholo_file_storage_bucket = "naholo-file-storage"