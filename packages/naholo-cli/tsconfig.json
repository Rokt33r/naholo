{
  "compilerOptions": {
    "types": ["node"],
    "target": "ES2022",
    "module": "Preserve",
    "moduleResolution": "Bundler",
    "rootDir": "./src",
    "resolveJsonModule": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": ["src"]
}
