{
  "permissions": {
    "allow": [
      "Edit(/.claude/skills/infil/**)",
      "Edit(/.claude/skills/exfil/**)",
      "Edit(/.claude/skills/spec/**)",
      "Edit(/.claude/skills/ship/**)",
      "Edit(/.claude/skills/sitrep/**)",
      "Bash(pnpm test-types *)",
      "Bash(pnpm format *)",
      "Bash(naholo agent *)",
      "Bash(pnpm vitest *)",
      "Bash(pnpm --filter @naholo/cli typecheck)",
      "Bash(pnpm typecheck *)",
      "Bash(git rm *)",
      "Bash(git log *)",
      "Bash(node -p \"require\\('./package.json'\\).version\")"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "naholo agent claude-code-stop"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "naholo-claude-plugin@naholo": true
  }
}
